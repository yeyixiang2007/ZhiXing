{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (PowerShell)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/build.ps1"
      ],
      "group": "build",
      "problemMatcher": "$javac"
    },
    {
      "label": "Run Main (PowerShell)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run.ps1"
      ],
      "dependsOn": "Build (PowerShell)"
    }
  ]
}

